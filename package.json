{
  "name": "markdown-live-previewer",
  "author": "Ian Huang",
  "description": "A desktop application for live previewing Markdown files.",
  "private": true,
  "version": "3.4.2",
  "type": "module",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "compile-electron": "tsc electron/main.ts --outDir electron --declaration false --target ES2020 --module esnext --lib ES2020 --skipLibCheck true --esModuleInterop true --moduleResolution node",
    "electron-dev": "npm run compile-electron && electron .",
    "electron-build": "cross-env VITE_ELECTRON=true npm run build && npm run electron-dist",
    "electron-dist": "npm run compile-electron && electron-builder",
    "dev-electron": "concurrently npm:dev npm:electron-dev",
    "dev-electron-wait": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron-dev\""
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.17",
    "@uiw/react-codemirror": "^4.25.8",
    "abcjs": "^6.6.2",
    "better-react-mathjax": "^3.0.0",
    "codemirror": "^6.0.2",
    "codemirror-lang-mermaid": "^0.5.0",
    "extend": "^3.0.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.2",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "smiles-drawer": "^2.1.7",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/codemirror-theme-vscode": "^4.25.8",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.9.1",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-require-transform": "^1.0.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.markdownlivepreviewer.app",
    "productName": "Markdown Live Previewer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}